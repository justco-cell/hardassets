# Build artifacts
dist/
build/
.next/
out/

# Dependencies
node_modules/
.pnp/
.pnp.js

# Environment files (never read by Claude Code)
.env
.env.local
.env.development.local
.env.production.local
.env.test.local

# Vercel
.vercel/

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
*.log

# OS files
.DS_Store
Thumbs.db

# Editor/IDE
.vscode/
.idea/
*.swp
*.swo

# Testing
coverage/
.nyc_output/

# Large binary assets (icons are small, leave them)
*.mp4
*.mov
*.zip
*.tar.gz

# Old uploaded file versions (keep git as source of truth)
*_backup.*
*_old.*
*_v[0-9].*

# Package manager lock files are OK to keep visible — Claude Code benefits from seeing them
# (intentionally NOT ignoring package-lock.json, yarn.lock, pnpm-lock.yaml)
